{
  "name": "codepilot",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile command center for AI coding agents",
  "scripts": {
    "build": "cargo build --workspace && cargo build -p codepilot-relay-worker --target wasm32-unknown-unknown",
    "build:bridge": "cargo build -p codepilot-bridge",
    "build:relay": "cargo build -p codepilot-relay-worker --target wasm32-unknown-unknown",
    "test": "cargo test --workspace",
    "test:bridge": "cargo test -p codepilot-bridge",
    "test:relay": "cargo test -p codepilot-relay-worker",
    "test:agents": "cargo test -p codepilot-agents",
    "check": "cargo test --workspace && cargo build -p codepilot-relay-worker --target wasm32-unknown-unknown",
    "bridge": "cargo run -p codepilot-bridge --",
    "bridge:help": "cargo run -p codepilot-bridge -- --help",
    "relay:dev": "cd crates/codepilot-relay-worker && npx wrangler dev",
    "relay:deploy": "cd crates/codepilot-relay-worker && npx wrangler deploy",
    "clean": "cargo clean"
  },
  "engines": {
    "node": ">=18"
  }
}
